# ──────────────────────────────────────────────────────────────────────────────
# Jane Communication Automation — Environment Variables
# Copy this file to .env and fill in the values before running locally.
# In production (Railway), set these as environment variables directly.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────────────────────
APP_ENV=development                        # 'development' or 'production'
APP_SECRET_KEY=change-me-to-a-long-random-string  # Generate: python -c "import secrets; print(secrets.token_hex(32))"
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info                         # debug | info | warning | error

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://jane_user:jane_pass@localhost:5432/jane_automation

# ── Session ────────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=8                        # Session lifetime in hours

# ── Anthropic / Claude ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...               # Required for AI categorization + drafts
CLAUDE_MODEL=claude-sonnet-4-5

# ── AI Budget (T2.3) ───────────────────────────────────────────────────────────
# Daily token budget across all Claude API calls. Set to 0 to disable.
DAILY_TOKEN_BUDGET=1000000

# ── Shadow Mode (T2.4) ─────────────────────────────────────────────────────────
# When True, emails are categorized but no AI drafts are auto-generated.
# Useful for initial deployment validation without sending AI-generated replies.
SHADOW_MODE=false

# ── Email Provider ─────────────────────────────────────────────────────────────
EMAIL_PROVIDER=imap                        # 'imap' or 'msgraph'

# MS Graph (required when EMAIL_PROVIDER=msgraph)
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_TENANT_ID=
MSGRAPH_MAILBOX=jane@example.com

# IMAP / SMTP (required when EMAIL_PROVIDER=imap)
# IMPORTANT: IMAP_USERNAME and SMTP_USERNAME MUST match for SPF/DKIM alignment.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USERNAME=jane@example.com
IMAP_PASSWORD=your-imap-password

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=jane@example.com             # Must match IMAP_USERNAME when EMAIL_PROVIDER=imap
SMTP_PASSWORD=your-smtp-password

# ── Polling ────────────────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL_SECONDS=60             # How often to check for new emails

# ── Notifications ──────────────────────────────────────────────────────────────
NOTIFY_LOG_FILE=                           # Optional: path to notification log file
SLACK_WEBHOOK_URL=                         # Optional: Slack webhook for escalation alerts

# ── Draft Generation ───────────────────────────────────────────────────────────
DRAFT_TEMPERATURE=0.3
DRAFT_MAX_TOKENS=1024
DRAFT_AUTO_GENERATE=true                   # Set to false to disable auto-generation
FIRM_NAME=Schiller CPA
FIRM_OWNER_NAME=Jane Schiller
FIRM_OWNER_EMAIL=jane@schilcpa.com

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Seed Admin ─────────────────────────────────────────────────────────────────
ADMIN_EMAIL=jane@example.com
ADMIN_NAME=Jane
ADMIN_PASSWORD=                            # Required to run seed script
