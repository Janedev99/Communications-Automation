# ──────────────────────────────────────────────────────────────────────────────
# Jane Communication Automation — Environment Variables
#
# Copy this file to `.env` and fill in the values.
# In production (Railway), set these as service-level environment variables.
# Never commit the populated `.env` file to version control.
#
# Field names match `backend/app/config.py` exactly. Anything not listed here
# is unused — if you find a stray var in some old config, delete it.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
# In production: APP_ENV=production. The config validator hard-fails on boot if
# you leave APP_SECRET_KEY at the dev default while APP_ENV=production.
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-long-random-string
# Generate a real one with:
#   python -c "import secrets; print(secrets.token_hex(32))"
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info                     # debug | info | warning | error

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# In Railway, this is provided by the Postgres service plugin — copy the value
# from the service's "Connect" tab. Format must use the psycopg2 dialect.
DATABASE_URL=postgresql+psycopg2://jane_user:jane_pass@localhost:5432/jane_automation

# ── docker-compose only — NOT used by the backend ─────────────────────────────
# These exist solely so docker-compose can stand up a local Postgres container.
# Railway and bare-metal deployments can ignore them.
POSTGRES_DB=jane_automation
POSTGRES_USER=jane_user
POSTGRES_PASSWORD=jane_pass

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=8

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get a key from https://console.anthropic.com → Settings → API Keys.
# Boot fails if APP_ENV=production and this key starts with "sk-ant-placeholder".
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me
CLAUDE_MODEL=claude-sonnet-4-5

# Daily token budget across all Claude calls. Once exceeded, the system falls
# back to the rules engine for the rest of the day. Set to 0 to disable cap.
DAILY_TOKEN_BUDGET=1000000

# When true, emails are categorized but no AI drafts are generated. Recommended
# for the first 24-48h of any new deployment.
SHADOW_MODE=false

# ── Email Provider ────────────────────────────────────────────────────────────
# Set EMAIL_PROVIDER to "msgraph" (recommended for Microsoft 365) or "imap"
# (Gmail, free Outlook, etc.). Only fill in the credentials for your chosen
# provider — the other set can stay blank.
EMAIL_PROVIDER=imap

# MS Graph (Azure app registration with Mail.Read + Mail.Send + Mail.ReadWrite
# application permissions, admin-consented).
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_TENANT_ID=
MSGRAPH_MAILBOX=jane@yourdomain.com

# IMAP / SMTP. IMPORTANT: IMAP_USERNAME and SMTP_USERNAME MUST match — the
# config validator rejects mismatches because they break SPF/DKIM alignment.
IMAP_HOST=imap.example.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USERNAME=jane@yourdomain.com
IMAP_PASSWORD=

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=jane@yourdomain.com
SMTP_PASSWORD=

# ── Polling ───────────────────────────────────────────────────────────────────
EMAIL_POLL_INTERVAL_SECONDS=60

# ── Notifications ─────────────────────────────────────────────────────────────
# At least one of NOTIFY_LOG_FILE or SLACK_WEBHOOK_URL is recommended so urgent
# items aren't missed. Both can be enabled simultaneously.
NOTIFY_LOG_FILE=
SLACK_WEBHOOK_URL=

# ── Draft Generation ──────────────────────────────────────────────────────────
DRAFT_TEMPERATURE=0.3
DRAFT_MAX_TOKENS=1024
DRAFT_AUTO_GENERATE=true
FIRM_NAME=Schiller CPA
FIRM_OWNER_NAME=Jane Schiller
FIRM_OWNER_EMAIL=jane@schilcpa.com

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed browser origins. In production, set this to
# your real frontend URL only — preflight rejects values containing localhost.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Trusted Proxies ───────────────────────────────────────────────────────────
# Comma-separated list of proxy IPs whose X-Forwarded-For header is trusted.
# In Railway, set this to the platform's edge IP (or leave blank to fall back
# to the direct connection IP — safer default if you don't know the IP).
TRUSTED_PROXIES=

# ── Frontend Build Arg (Next.js) ──────────────────────────────────────────────
# Inlined at build time — must be passed as a Docker build-arg, not a runtime
# environment variable. In Railway, set it under "Build" on the frontend
# service, not "Variables".
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── First Admin Account ───────────────────────────────────────────────────────
# Used by `python scripts/seed_admin.py` on first boot. The seed script is
# idempotent — re-runs on subsequent deploys are no-ops.
ADMIN_EMAIL=jane@yourdomain.com
ADMIN_NAME=Jane
ADMIN_PASSWORD=change-me-before-deploying
