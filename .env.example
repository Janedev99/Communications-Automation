# ─────────────────────────────────────────────
# Jane Communication Automation — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── Application ───────────────────────────────
APP_ENV=development            # development | production
APP_SECRET_KEY=change-me-to-a-long-random-string-in-production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info             # debug | info | warning | error

# ── Database (PostgreSQL) ─────────────────────
DATABASE_URL=postgresql+psycopg2://jane_user:jane_pass@db:5432/jane_automation
# Async variant used by some drivers (keep in sync with above)
DATABASE_URL_ASYNC=postgresql+asyncpg://jane_user:jane_pass@db:5432/jane_automation

POSTGRES_DB=jane_automation
POSTGRES_USER=jane_user
POSTGRES_PASSWORD=jane_pass

# ── Session ────────────────────────────────────
SESSION_TTL_HOURS=8            # How long a login session lasts

# ── Anthropic / Claude ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-5  # Override to pin a specific model version

# ── Email Provider ─────────────────────────────
# Set EMAIL_PROVIDER to "msgraph" or "imap"
EMAIL_PROVIDER=imap

# MS Graph (Azure AD app registration)
MSGRAPH_CLIENT_ID=
MSGRAPH_CLIENT_SECRET=
MSGRAPH_TENANT_ID=
MSGRAPH_MAILBOX=jane@yourdomain.com    # The shared/monitored mailbox

# IMAP / SMTP fallback
IMAP_HOST=imap.yourmailprovider.com
IMAP_PORT=993
IMAP_USE_SSL=true
IMAP_USERNAME=jane@yourdomain.com
IMAP_PASSWORD=
SMTP_HOST=smtp.yourmailprovider.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USERNAME=jane@yourdomain.com
SMTP_PASSWORD=

# ── Polling ────────────────────────────────────
EMAIL_POLL_INTERVAL_SECONDS=60    # How often to check for new emails

# ── Notifications ──────────────────────────────
# V1 uses log-based notifications only.
# Set NOTIFY_LOG_FILE to a path to write notifications there,
# or leave empty to use stdout only.
NOTIFY_LOG_FILE=

# Future Slack integration (not active in V1)
SLACK_WEBHOOK_URL=

# ── Draft Generation ──────────────────────────
DRAFT_TEMPERATURE=0.3          # Temperature for draft generation (0.3 = consistent but natural)
DRAFT_MAX_TOKENS=1024          # Max tokens per generated draft
DRAFT_AUTO_GENERATE=true       # Set false to require manual draft trigger per thread
FIRM_NAME=Schiller CPA         # Used in AI system prompt to establish firm identity
FIRM_OWNER_NAME=Jane Schiller  # Firm owner name for prompt context
FIRM_OWNER_EMAIL=jane@schilcpa.com  # Firm owner email shown in prompt context

# ── Frontend (Next.js) ────────────────────────
# The browser-facing URL of the backend API.
# Must be passed as a Docker build arg (NEXT_PUBLIC_* vars are baked in at
# build time by Next.js — runtime environment vars have no effect on them).
# In docker-compose this is set via the `build.args` section.
# In Railway / other hosts, set it as a build-time variable, NOT a runtime env.
NEXT_PUBLIC_API_URL=http://localhost:8001

# ── Trusted Proxies (rate-limiter) ────────────
# Comma-separated list of trusted proxy IPs (e.g. Caddy, Railway load-balancer).
# When set, X-Forwarded-For is trusted only if the request comes from one of
# these addresses. Leave empty to always use the direct connection IP.
TRUSTED_PROXIES=

# ── First Admin Account ─────────────────────────
# Used by the database seed script on first run
ADMIN_EMAIL=jane@yourdomain.com
ADMIN_NAME=Jane
ADMIN_PASSWORD=change-me-before-deploying
